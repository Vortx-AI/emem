  "_meta": {
    "schema": "emem.eval.v2",
    "purpose": "Comprehensive consumer-focused evaluation of emem /v1/ask routing + materialize fidelity. Covers new question types (intent-driven, multi-hop, comparative, lifestyle), new locations (deliberately disjoint from scripts/eval/questions.json), and high-volume real-world AI-agent query patterns drawn from public discourse: r/RealEstate, r/climatechange, r/Insurance, climate-migration journalism, parametric-insurance trade press, agriculture extension queries, and global news headlines 2023-2026.",
    "design_principles": [
      "Phrase like a worried consumer or a journalist, not like a GIS analyst.",
      "Locations deliberately new vs the existing 51-question set.",
      "Each question carries an `intent` tag so we can score volume-weighted accuracy.",
      "Each question carries `severity` (1-5) reflecting real-world stakes.",
      "Each question carries `volume_signal` — qualitative estimate of public-search/AI-agent volume."
    ],
    "expected_topic_keys_reference": "crates/emem-core/data/topics-v0.json"
  },
